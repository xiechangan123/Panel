{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "🤖 Dependencies"
  ],
  "commitMessagePrefix": "chore(deps): ",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "platformAutomerge": true,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "groupName": "non-major dependencies",
      "matchUpdateTypes": [
        "digest",
        "pin",
        "patch",
        "minor"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "groupName": "major dependencies",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": false
    }
  ],
  "ignoreDeps": [
    "eslint"
  ]
}
